{
  "name": "totem-dapp-starter",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal dApp starter implementing TOTEM_CONNECT v4.1 patterns",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test server/auth-verify.test.js"
  },
  "dependencies": {
    "@totem/observability": "workspace:*",
    "@totemsdk/core": "workspace:*",
    "@totemsdk/proof-integritas": "workspace:*",
    "@totemsdk/root-identity": "workspace:*",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4"
  }
}
