# Copy this file to .env and fill in your values.
# Never commit .env — add it to .gitignore.

# Your Axia API key (from https://api.axia.to)
# This key stays on the server — it is NEVER sent to the browser.
AXIA_API_KEY=axia_key_your_key_here

# Express backend port (default: 3001)
PORT=3001

# HMAC-SHA256 secret used to sign session tokens.
# MUST be set in production — without it a new random secret is generated on
# every startup, which invalidates all active sessions after each restart and
# prevents tokens from being accepted by other server instances.
#
# Generate a strong secret (run once in your terminal):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# For multi-server deployments all instances must share the same value.
SESSION_SECRET=replace_with_64_hex_chars_generated_above

# Integritas API key for on-chain hash anchoring (https://integritas.minima.global).
# Optional — public hashes can be stamped without a key, but rate limits apply.
# This key stays on the server — it is NEVER sent to the browser.
# INTEGRITAS_API_KEY=integritas_key_your_key_here

# Integritas base URL (default: https://integritas.minima.global/core/v2)
# Only override this if you are running a private Integritas node.
# INTEGRITAS_BASE_URL=https://integritas.minima.global/core/v2

# Redis connection URL for the server-side session store.
# When set, session records are stored in Redis and survive server restarts.
# All server instances must point to the same Redis instance.
# When not set, an in-memory Map is used — sessions are lost on restart.
#
# Format: redis://[:password@]host[:port][/db]
# Example: redis://default:mypassword@redis.example.com:6379
#
# Recommended providers: Redis Cloud (free tier), Upstash, Railway, Fly.io
# REDIS_URL=redis://localhost:6379
