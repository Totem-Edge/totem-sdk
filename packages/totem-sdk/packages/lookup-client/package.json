{
  "name": "@totemsdk/lookup-client",
  "version": "0.1.5",
  "description": "Hyperswarm client for Totem lookup nodes — chain queries, real-time coin updates, and TxPoW broadcast without a local chain DB",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@totemsdk/core": "^1.1.0",
    "@totemsdk/lookup-protocol": "^0.1.3",
    "@totemsdk/chain-provider": "^0.1.4",
    "@totemsdk/stream-transport": "^0.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Totem SDK",
  "homepage": "https://totem.ing",
  "bugs": {
    "url": "https://github.com/MrGheek/totem-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrGheek/totem-sdk.git",
    "directory": "packages/totem-sdk/packages/lookup-client"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
