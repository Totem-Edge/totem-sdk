{
  "name": "@totemsdk/omnia-router",
  "version": "0.1.4",
  "description": "Multi-hop payment routing over Omnia channels — single-token and cross-token paths",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:go": "cd go && go build -o ../bin/omnia-router .",
    "prepare": "tsc",
    "clean": "rm -rf dist bin",
    "test": "node ../../node_modules/jest/bin/jest.js --config jest.config.cjs --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@totemsdk/core": "^1.1.0"
  },
  "peerDependencies": {
    "@totemsdk/omnia": ">=0.1.5"
  },
  "peerDependenciesMeta": {
    "@totemsdk/omnia": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.0.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Totem SDK",
  "homepage": "https://totem.ing",
  "bugs": {
    "url": "https://github.com/totem-sdk/totem-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/totem-sdk/totem-sdk.git",
    "directory": "packages/totem-sdk/packages/omnia-router"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "kissvm",
    "utxo",
    "omnia",
    "payment-channel",
    "eltoo",
    "layer2",
    "routing",
    "multi-hop",
    "htlc",
    "dijkstra"
  ]
}
