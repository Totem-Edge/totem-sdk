{
  "name": "@totemsdk/edge",
  "version": "0.1.3",
  "description": "Unified developer-facing runtime for Totem Edge — composes identity, manifest, wallet/payment/proof/lookup/policy capabilities via injected ports",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@totemsdk/core": "^1.1.0",
    "@totemsdk/manifest": "^0.1.2",
    "@totemsdk/identity": "^0.1.2",
    "@totemsdk/agent-policy": "^0.1.3"
  },
  "peerDependencies": {
    "@totemsdk/connect": "^2.1.0"
  },
  "peerDependenciesMeta": {
    "@totemsdk/connect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@totemsdk/connect": "^2.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.0.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Totem SDK",
  "homepage": "https://totem.ing",
  "bugs": {
    "url": "https://github.com/MrGheek/totem-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrGheek/totem-sdk.git",
    "directory": "packages/totem-sdk/packages/edge"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "kissvm",
    "utxo"
  ]
}
