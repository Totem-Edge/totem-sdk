{
  "name": "@totemsdk/core",
  "version": "1.1.0",
  "description": "Core cryptographic primitives for Totem SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "require": "./dist/adapters/index.js",
      "import": "./dist/adapters/index.js"
    },
    "./adapters/types": {
      "types": "./dist/adapters/types.d.ts",
      "require": "./dist/adapters/types.js",
      "import": "./dist/adapters/types.js"
    },
    "./lease": {
      "types": "./dist/lease/index.d.ts",
      "require": "./dist/lease/index.js",
      "import": "./dist/lease/index.js"
    },
    "./tx": {
      "types": "./dist/tx/index.d.ts",
      "require": "./dist/tx/index.js",
      "import": "./dist/tx/index.js"
    },
    "./scripts": {
      "types": "./dist/scripts/index.d.ts",
      "require": "./dist/scripts/index.js",
      "import": "./dist/scripts/index.js"
    },
    "./test-vectors.json": "./test-vectors.json"
  },
  "typesVersions": {
    "*": {
      "adapters": [
        "./dist/adapters/index.d.ts"
      ],
      "adapters/types": [
        "./dist/adapters/types.d.ts"
      ],
      "lease": [
        "./dist/lease/index.d.ts"
      ],
      "tx": [
        "./dist/tx/index.d.ts"
      ],
      "scripts": [
        "./dist/scripts/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests",
    "gen:pkdigest": "node scripts/gen_wots_pkdigest_vectors.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {},
  "peerDependencies": {
    "@noble/hashes": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@noble/hashes": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@noble/hashes": "^2.2.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Totem SDK",
  "homepage": "https://totemsdk.com",
  "bugs": {
    "url": "https://github.com/MrGheek/axia-totem/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrGheek/axia-totem.git",
    "directory": "packages/totem-sdk/packages/core"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "kissvm",
    "utxo"
  ]
}
