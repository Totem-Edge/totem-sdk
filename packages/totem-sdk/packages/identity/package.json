{
  "name": "@totemsdk/identity",
  "version": "0.1.3",
  "description": "Canonical identity and claims layer for Totem Edge — who controls a manifest, device, or agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:wasm && tsc",
    "build:wasm": "cd rust && wasm-pack build --target bundler --out-dir pkg && wasm-pack build --target nodejs --out-dir pkg-node",
    "prepare": "npm run build:wasm && tsc",
    "clean": "rm -rf dist rust/pkg rust/pkg-node rust/target",
    "test": "jest --passWithNoTests"
  },
  "files": [
    "dist",
    "rust/pkg/",
    "rust/pkg-node/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@totemsdk/core": "^1.1.0",
    "@totemsdk/manifest": "^0.1.2"
  },
  "devDependencies": {
    "@totemsdk/root-identity": "^1.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.0.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Totem SDK",
  "homepage": "https://totem.ing",
  "bugs": {
    "url": "https://github.com/totem-sdk/totem-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/totem-sdk/totem-sdk.git",
    "directory": "packages/totem-sdk/packages/identity"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "kissvm",
    "utxo",
    "identity",
    "did"
  ]
}
