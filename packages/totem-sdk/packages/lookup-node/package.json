{
  "name": "@totemsdk/lookup-node",
  "version": "0.1.4",
  "description": "Always-on personal lookup node — accepts Hyperswarm connections, answers chain queries, pushes COIN_UPDATE to watchlist subscribers, relays TxPoW, and coordinates WOTS leases",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && rm -rf dist/__tests__",
    "prepare": "tsc && rm -rf dist/__tests__",
    "prepack": "rm -rf dist/__tests__",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@totemsdk/core": "^1.1.0",
    "@totemsdk/lookup-protocol": "^0.1.3",
    "@totemsdk/chain-provider": "^0.1.4",
    "@totemsdk/pureminima-rpc": "^0.1.3",
    "@totemsdk/wots-lease": "^0.1.3",
    "@totemsdk/txpow": "^0.1.5",
    "better-sqlite3": "^12.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Totem SDK",
  "homepage": "https://totem.ing",
  "bugs": {
    "url": "https://github.com/MrGheek/totem-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrGheek/totem-sdk.git",
    "directory": "packages/totem-sdk/packages/lookup-node"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "kissvm",
    "utxo",
    "hyperswarm",
    "p2p"
  ]
}
