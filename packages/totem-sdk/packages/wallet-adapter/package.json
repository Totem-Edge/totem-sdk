{
  "name": "@totemsdk/wallet-adapter",
  "version": "0.1.0",
  "description": "Abstract base class for building Totem-compatible wallets — hardware bridges, mobile companions, institutional custody wallets",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "clean": "rm -rf dist",
    "test": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@totemsdk/chain-provider": ">=0.1.3"
  },
  "peerDependenciesMeta": {
    "@totemsdk/chain-provider": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "author": "Totem SDK",
  "homepage": "https://totemsdk.com",
  "bugs": {
    "url": "https://github.com/MrGheek/axia-totem/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrGheek/axia-totem.git",
    "directory": "packages/totem-sdk/packages/wallet-adapter"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "kissvm",
    "utxo",
    "wallet-adapter",
    "hardware-wallet",
    "custody",
    "totem-announce",
    "multi-wallet"
  ]
}
