{
  "description": "WatermarkStore expected behavior fixtures based on legacy Totem Wallet implementation",
  "version": "1.0.0",
  "scenarios": [
    {
      "name": "initialize_default",
      "input": {
        "operation": "initialize"
      },
      "expectedOutput": {
        "next_addressIndex": 0,
        "next_l1": 0,
        "next_l2": 0,
        "usedIndices": []
      }
    },
    {
      "name": "advance_watermark_simple",
      "input": {
        "operation": "advanceWatermark",
        "currentIndices": { "addressIndex": 0, "l1": 0, "l2": 0 }
      },
      "expectedOutput": {
        "next_addressIndex": 0,
        "next_l1": 0,
        "next_l2": 1
      }
    },
    {
      "name": "advance_watermark_l2_overflow",
      "input": {
        "operation": "advanceWatermark",
        "currentIndices": { "addressIndex": 0, "l1": 0, "l2": 63 }
      },
      "expectedOutput": {
        "next_addressIndex": 0,
        "next_l1": 1,
        "next_l2": 0
      }
    },
    {
      "name": "advance_watermark_l1_overflow",
      "input": {
        "operation": "advanceWatermark",
        "currentIndices": { "addressIndex": 0, "l1": 63, "l2": 63 }
      },
      "expectedOutput": {
        "next_addressIndex": 1,
        "next_l1": 0,
        "next_l2": 0
      }
    },
    {
      "name": "server_sync_advance",
      "input": {
        "operation": "updateFromServer",
        "localState": { "next_addressIndex": 0, "next_l1": 0, "next_l2": 0 },
        "serverWatermark": { "addressIndex": 1, "l1": 2, "l2": 3 }
      },
      "expectedOutput": {
        "updated": true,
        "next_addressIndex": 1,
        "next_l1": 2,
        "next_l2": 3
      }
    },
    {
      "name": "server_sync_no_regress",
      "input": {
        "operation": "updateFromServer",
        "localState": { "next_addressIndex": 5, "next_l1": 0, "next_l2": 0 },
        "serverWatermark": { "addressIndex": 1, "l1": 0, "l2": 0 }
      },
      "expectedOutput": {
        "updated": false,
        "next_addressIndex": 5,
        "next_l1": 0,
        "next_l2": 0
      }
    }
  ]
}
