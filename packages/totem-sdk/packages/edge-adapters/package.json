    "@totemsdk/chain-provider": { "optional": true },
    "@totemsdk/identity": { "optional": true },
    "@totemsdk/manifest": { "optional": true },
    "@totemsdk/omnia-router": { "optional": true },
    "@totemsdk/proof": { "optional": true },
    "@totemsdk/lookup-client": { "optional": true },
    "@totemsdk/root-identity": { "optional": true }
  },
  "devDependencies": {
    "@totemsdk/agent-policy": "workspace:*",
