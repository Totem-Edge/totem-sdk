    "@totemsdk/omnia-router": "workspace:*",
    "@totemsdk/proof": "workspace:*",
    "@totemsdk/lookup-client": "workspace:*",
    "@totemsdk/root-identity": "workspace:*",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
