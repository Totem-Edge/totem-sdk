{
  "name": "@totemsdk/edge-adapters",
  "version": "0.1.0",
  "description": "Reference adapters bridging Totem SDK packages to @totemsdk/edge port interfaces",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "clean": "rm -rf dist",
