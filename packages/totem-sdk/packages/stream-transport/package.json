{
  "name": "@totemsdk/stream-transport",
  "version": "0.1.0",
  "description": "Transport adapters for Totem SDK — IStreamTransport interface, NodeStream, WebSocket, WebRTC, Stdio, Hyperswarm, and in-memory transports",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@noble/hashes": "^2.2.0"
  },
  "peerDependencies": {
    "@noble/hashes": "^2.0.0",
    "hyperswarm": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@noble/hashes": {
      "optional": false
    },
    "hyperswarm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
