    "prepare": "tsc",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@totemsdk/core": "workspace:^1.1.0",
