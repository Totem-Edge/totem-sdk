{
  "name": "@totemsdk/edge-mqtt",
  "version": "0.2.0",
  "description": "MQTT adapter for Totem Edge — Rust/WASM-backed canonicalization, topic matching, and MachinePay arithmetic",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:wasm && tsc",
    "build:wasm": "cd rust && wasm-pack build --target bundler --out-dir pkg && wasm-pack build --target nodejs --out-dir pkg-node",
    "prepare": "npm run build:wasm && tsc",
    "clean": "rm -rf dist rust/pkg rust/pkg-node rust/target",
    "test": "jest --passWithNoTests"
  },
  "files": [
    "dist",
    "rust/pkg/",
    "rust/pkg-node/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@totemsdk/core": "^1.1.0",
    "@totemsdk/manifest": "^0.1.2",
    "@totemsdk/identity": "^0.1.2",
    "@totemsdk/edge": "^0.1.2",
    "@totemsdk/proof": "^0.1.1",
    "@totemsdk/agent-policy": "^0.1.3",
    "@totemsdk/pubsub-transport": "^0.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.0.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Totem SDK",
  "homepage": "https://totem.ing",
  "bugs": {
    "url": "https://github.com/MrGheek/totem-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrGheek/totem-sdk.git",
    "directory": "packages/totem-sdk/packages/edge-mqtt"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "kissvm",
    "utxo",
    "mqtt",
    "iot",
    "edge",
    "sensor",
    "gateway",
    "machinepay",
    "pear",
    "hyperswarm",
    "bare"
  ]
}
