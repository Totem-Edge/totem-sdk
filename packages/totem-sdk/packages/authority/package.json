{
  "name": "@totemsdk/authority",
  "version": "0.1.2",
  "description": "Deterministic authority engine for Totem Edge — mandate verification, scope matching, usage tracking, and authority evaluation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:wasm && tsc",
    "build:wasm": "cd rust && wasm-pack build --target bundler --out-dir pkg && wasm-pack build --target nodejs --out-dir pkg-node",
    "prepare": "npm run build:wasm && tsc",
    "clean": "rm -rf dist rust/pkg rust/pkg-node rust/target",
    "test": "jest --passWithNoTests"
  },
  "files": [
    "dist",
    "rust/pkg/",
    "rust/pkg-node/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@totemsdk/proof": "^0.1.1",
    "@totemsdk/identity": "^0.1.2"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^26.1.1",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "authority",
    "mandate",
    "governance",
    "edge-computing",
    "cryptography"
  ],
  "bugs": {
    "url": "https://github.com/totem-sdk/totem-sdk/issues"
  },
  "license": "MIT",
  "author": "Totem SDK",
  "homepage": "https://totem.ing",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/totem-sdk/totem-sdk.git",
    "directory": "packages/totem-sdk/packages/authority"
  }
}
