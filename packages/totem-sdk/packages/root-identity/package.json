{
  "name": "@totemsdk/root-identity",
  "version": "1.0.7",
  "description": "Single root identity controlling up to 64 on-chain addresses — all cryptographically linked via full independent 3-level TreeKeys",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bare": "./dist/index.js",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "npm run build:wasm && tsc",
    "prepare": "npm run build:wasm && tsc",
    "clean": "rm -rf dist rust/pkg rust/pkg-node rust/target",
    "pretest": "cd ../core && npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
    "build:wasm": "cd rust && wasm-pack build --target bundler --out-dir pkg && wasm-pack build --target nodejs --out-dir pkg-node"
  },
  "files": [
    "dist",
    "rust/pkg/",
    "rust/pkg-node/",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@totemsdk/core": ">=1.0.1"
  },
  "peerDependenciesMeta": {
    "@totemsdk/core": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=16.0.0",
    "bare": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@totemsdk/core": "^1.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.0.0",
    "typescript": "^7.0.2"
  },
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "kissvm",
    "utxo",
    "identity",
    "did",
    "chain-of-custody",
    "dao-attestation",
    "kyc"
  ],
  "author": "Totem SDK",
  "license": "MIT",
  "homepage": "https://totem.ing",
  "bugs": {
    "url": "https://github.com/totem-sdk/totem-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/totem-sdk/totem-sdk.git",
    "directory": "packages/totem-sdk/packages/root-identity"
  }
}
