{
  "name": "@totem/sdk",
  "version": "1.0.0",
  "description": "Official Totem blockchain SDK for multi-platform development",
  "private": true,
  "scripts": {
    "build": "npm run build:core && npm run build:txpow && npm run build:server && npm run build:root-identity",
    "build:core": "cd packages/core && npm run build",
    "build:txpow": "cd packages/txpow && npm run build",
    "build:server": "cd packages/server && npm run build",
    "build:root-identity": "cd packages/root-identity && npm run build",
    "test": "cd packages/core && npm test && cd ../txpow && npm test",
    "clean": "for d in packages/*/; do (cd \"$d\" && npm run clean); done",
    "smoke-test": "node scripts/smoke-test-imports.mjs",
    "prepack": "node scripts/smoke-test-imports.mjs",
    "docs": "typedoc",
    "validate:meta": "node scripts/validate-pkg-meta.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/totem-sdk/totem-sdk.git",
    "directory": "packages/totem-sdk"
  },
  "bugs": {
    "url": "https://github.com/totem-sdk/totem-sdk/issues"
  },
  "homepage": "https://totem.ing",
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "cryptography",
    "sdk"
  ],
  "author": "Totem SDK",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typedoc": "^0.25.0",
    "typescript": "^7.0.2"
  }
}
