/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.axia.to wss://api.axia.to https://*.axia.to; img-src 'self' data: blob:; font-src 'self'; worker-src 'self' blob:; frame-ancestors 'none'; form-action 'self'; navigate-to 'self' https: web+totem: myapp:; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Main wallet app — strict isolation (COOP/COEP + no framing)
/index.html
  X-Frame-Options: DENY
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Approval popup pages — MUST NOT have COOP so window.opener is preserved.
# Both desktop (popup) and mobile (new tab opened by window.open) flows rely on
# window.opener?.postMessage() to return the signed result to the dApp page.
# Setting COOP: same-origin here would null out window.opener cross-origin.
# No X-Frame-Options so cross-origin dApps can embed approval flows if needed.
# CORS * so provider.js (injected on any origin) can fetch approval results.
/approval/*
  Cross-Origin-Opener-Policy: unsafe-none
  Access-Control-Allow-Origin: *

/provider.js
  Access-Control-Allow-Origin: *
  Content-Type: application/javascript
  Cross-Origin-Resource-Policy: cross-origin
  Cache-Control: public, max-age=3600

/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: no-cache
