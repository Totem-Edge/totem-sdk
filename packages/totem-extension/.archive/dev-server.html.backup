<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Totem Wallet - Dev Server</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .container {
      max-width: 1200px;
      width: 100%;
    }

    .header {
      text-align: center;
      margin-bottom: 30px;
      color: white;
    }

    .header h1 {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 8px;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
    }

    .header p {
      font-size: 14px;
      opacity: 0.9;
    }

    .controls {
      background: white;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    }

    .controls h2 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 15px;
      color: #333;
    }

    .control-row {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
    }

    .control-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .control-group label {
      font-size: 12px;
      font-weight: 500;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .btn {
      padding: 8px 16px;
      border: 2px solid #667eea;
      background: white;
      color: #667eea;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .btn:hover {
      background: #667eea;
      color: white;
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    .btn:active {
      transform: translateY(0);
    }

    .btn.active {
      background: #667eea;
      color: white;
    }

    .extension-container {
      background: white;
      border-radius: 12px;
      padding: 30px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    .extension-frame {
      border: 3px solid #2d3748;
      border-radius: 8px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      background: #0f172a;
      overflow: hidden;
      transition: all 0.3s ease;
    }

    iframe {
      display: block;
      border: none;
    }

    .info {
      margin-top: 15px;
      padding: 12px;
      background: #f7fafc;
      border-radius: 6px;
      font-size: 12px;
      color: #4a5568;
      border-left: 3px solid #667eea;
    }

    .info strong {
      color: #2d3748;
    }

    .status {
      display: inline-block;
      padding: 4px 8px;
      background: #48bb78;
      color: white;
      font-size: 11px;
      font-weight: 600;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Totem Wallet Dev Server</h1>
      <p>Standalone development environment for UI iteration • <span class="status">RUNNING</span></p>
    </div>

    <div class="controls">
      <h2>Browser Viewport Presets</h2>
      <div class="control-row">
        <button class="btn active" onclick="setViewport(400, 600)">
          Chrome/Edge (400×600)
        </button>
        <button class="btn" onclick="setViewport(380, 580)">
          Firefox (380×580)
        </button>
        <button class="btn" onclick="setViewport(420, 620)">
          Safari (420×620)
        </button>
        <button class="btn" onclick="setViewport(340, 520)">
          Compact (340×520)
        </button>
      </div>

      <div class="info">
        <strong>Design Constraint:</strong> Always design for Firefox's 380px minimum width. This ensures cross-browser compatibility. 
        The extension uses a <strong>flat brutalist design</strong> with white (#FFFFFF), burnt orange (#FF6B35), and slate gray (#475569).
      </div>
    </div>

    <div class="extension-container">
      <div class="extension-frame" id="frame">
        <iframe
          id="totem-iframe"
          src="./dev-popup.html"
          width="400"
          height="600"
          title="Totem Extension Popup"
        ></iframe>
      </div>
    </div>
  </div>

  <script>
    function setViewport(width, height) {
      const iframe = document.getElementById('totem-iframe');
      const frame = document.getElementById('frame');
      
      iframe.width = width;
      iframe.height = height;
      
      // Update active button
      document.querySelectorAll('.btn').forEach(btn => {
        btn.classList.remove('active');
      });
      event.target.classList.add('active');
      
      console.log(`Viewport changed to ${width}×${height}px`);
    }

    // Auto-refresh iframe when Vite HMR detects changes
    if (import.meta.hot) {
      import.meta.hot.on('vite:beforeUpdate', () => {
        console.log('[Totem Dev] Hot reload triggered');
      });
    }
  </script>
</body>
</html>
