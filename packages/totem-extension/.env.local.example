# Totem Wallet Designer - Live Testing Mode Configuration
# Copy this file to .env.local and fill in your values

# Axia API URL for live blockchain testing
# Use Replit dev URL during development, or production URL for testing
# Example (Replit dev): https://your-workspace.repl.co
# Example (Production): https://api.axia.to
VITE_AXIA_API_URL=

# Your Axia project ID from the dashboard
# Get this from: https://dashboard.axia.to/projects
# This is used for API authentication and quota tracking
VITE_AXIA_PROJECT_ID=

# NOTE: These values are ONLY used in Designer mode (dev-popup.html)
# They are NOT bundled in production builds
# Leave empty to use mock blockchain data
