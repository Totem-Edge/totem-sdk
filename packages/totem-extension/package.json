{
  "name": "totem-extension",
  "version": "1.0.0",
  "description": "Totem browser extension — quantum-resistant wallet for the Minima network",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/totem-sdk/totem-sdk.git",
    "directory": "packages/totem-extension"
  },
  "bugs": {
    "url": "https://github.com/totem-sdk/totem-sdk/issues"
  },
  "homepage": "https://totem.ing",
  "author": "Totem SDK",
  "license": "MIT",
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "browser-extension",
    "wallet",
    "chrome-extension"
  ],
  "main": "src/keyring.ts",
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "scripts": {
    "build": "npm run build:artifact",
    "build:artifact": "rm -rf dist && NODE_ENV=production WOTS_PARAMSET=v2-spec webpack --mode=production && echo '✅ Production artifact built - ready for distribution'",
    "dev": "NODE_ENV=development WOTS_PARAMSET=v2-spec DESIGNER_MODE=true webpack --mode=development --watch",
    "dev:ui": "NODE_ENV=development DESIGNER_MODE=true vite --config vite.dev.config.ts",
    "test": "jest test/precision.test.ts test/wots-signing.test.ts test/golden-vectors.test.ts && npm run test:verify-binding",
    "test:verify-binding": "node --test test/totem-verify-v41-binding.test.mjs",
    "test:unit": "jest test/precision.test.ts test/wots-signing.test.ts test/golden-vectors.test.ts --verbose",
    "test:integration": "jest test/transaction-flow.integration.test.ts --verbose",
    "test:all": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:golden": "jest test/golden-vectors.test.ts --verbose",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:create": "npx playwright test create-wallet",
    "test:e2e:import": "npx playwright test import-wallet",
    "test:e2e:unlock": "npx playwright test unlock-wallet",
    "test:e2e:recovery": "npx playwright test service-worker-recovery",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@totemsdk/core": "^1.1.0",
    "@totemsdk/realtime": "^0.1.9",
    "@totemsdk/root-identity": "^1.0.7",
    "@totemsdk/txpow": "^0.1.6",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.0",
    "jsqr": "^1.4.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "overrides": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.4",
    "postcss": "^8.4.32",
    "postcss-loader": "^8.2.0",
    "sharp": "^0.34.5",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.0",
    "vite-plugin-node-polyfills": "^0.17.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFiles": [
      "<rootDir>/test/setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!@totemsdk)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "test/keyring.test.ts",
      "test/serializer.golden.test.ts",
      "tests/"
    ]
  }
}
