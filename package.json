{
  "name": "totem-sdk",
  "version": "1.0.0",
  "private": true,
  "description": "Totem SDK monorepo — quantum-resistant decentralized computing platform for the Minima network",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/totem-sdk/totem-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/totem-sdk/totem-sdk/issues"
  },
  "homepage": "https://totem.ing",
  "author": "Totem SDK",
  "license": "MIT",
  "keywords": [
    "totem",
    "totemsdk",
    "minima",
    "blockchain",
    "quantum-resistant",
    "wots",
    "kissvm",
    "utxo",
    "payment-channels",
    "edge-computing",
    "cryptography"
  ],
  "scripts": {
    "build:sdk": "cd packages/totem-sdk && npm run build",
    "build:extension": "cd packages/totem-extension && npm run build",
    "test:sdk": "cd packages/totem-sdk && npm test",
    "test:extension": "cd packages/totem-extension && npm test",
    "docs": "cd TotemEdgeSDKDocs && npm run build:deploy",
    "smoke:wots:prepare": "node scripts/smoke-wots-prepare.mjs",
    "smoke:wots:e2e": "node scripts/smoke-wots-e2e.mjs",
    "serve:wots:prod": "node scripts/serve-wots-prod.mjs"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
