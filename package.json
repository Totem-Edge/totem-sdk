{
  "name": "totem-sdk",
  "version": "1.0.0",
  "private": true,
  "description": "Totem SDK monorepo — cryptographic primitives, browser extension, PWA wallet, and dApp starter",
  "scripts": {
    "build:sdk": "cd packages/totem-sdk && npm run build",
    "build:extension": "cd packages/totem-extension && npm run build",
    "test:sdk": "cd packages/totem-sdk && npm test",
    "test:extension": "cd packages/totem-extension && npm test",
    "docs": "cd TotemEdgeSDKDocs && npm run build:deploy",
    "smoke:wots:prepare": "node scripts/smoke-wots-prepare.mjs",
    "smoke:wots:e2e": "node scripts/smoke-wots-e2e.mjs",
    "serve:wots:prod": "node scripts/serve-wots-prod.mjs"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
