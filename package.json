    "test:kissvm": "vitest run packages/totem/packages/kissvm-harness",
    "build:wots": "cd packages/totem/packages/wots && npm run build",
    "build": "npm run build:wots",
    "test:changed": "pnpm -r test --workspace-concurrency=1",
    "bench": "pnpm -r bench",
    "bench:wots": "pnpm --filter @totem/wots bench",
    "dev:dashboard": "tsx server/main.ts",
    "db:push": "drizzle-kit push",
    "build:dashboard": "cd client && npm run build",
    "check:readme-api-sync": "node scripts/check-readme-api-sync.js",
    "docs": "pnpm --filter totem-edge-sdk-docs run generate && pnpm --filter totem-edge-sdk-docs run start",
    "docs:build": "pnpm --filter totem-edge-sdk-docs run build:deploy"
  },
